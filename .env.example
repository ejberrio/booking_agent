# Copia este archivo a .env y completa los valores.
# NUNCA subas .env al repositorio.

# === General ===
ENVIRONMENT=development

# === Base de datos (Postgres) ===
DATABASE_URL=postgresql+asyncpg://booking:booking@localhost:5432/booking

# === API (FastAPI) ===
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
SECRET_KEY=cambia-esto-por-un-valor-aleatorio

# === LLM (multi-proveedor vía LiteLLM) ===
# Provider: openai | anthropic | google | ...
LLM_PROVIDER=openai
# Modelo barato para tareas generales / desarrollo
LLM_MODEL=gpt-4o-mini
# Modelo capaz para el loop del agente que aplica cambios de precio (Fase 4)
LLM_MODEL_ACTIONS=gpt-4o
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Guarda de presupuesto (opcional)
LLM_MAX_USD_PER_DAY=5

# === Channel Manager: Beds24 (API V1, API Key de cuenta) ===
# beds24 | hostaway | smoobu | channex
CHANNEL_MANAGER=beds24
# API Key de cuenta de Beds24 (Account Access -> API Key 1, con Allow Writes = Yes).
BEDS24_API_KEY=
# propKey de la propiedad (>=16 caracteres): REQUERIDO para leer/escribir tarifas y reservas.
# En Beds24: Settings -> Properties -> tu propiedad -> propKey/Access.
BEDS24_PROP_KEY=
# Identificadores de tu propiedad/habitación en Beds24 (no secretos).
BEDS24_PROP_ID=
BEDS24_ROOM_ID=
BEDS24_BASE_URL=https://api.beds24.com/json
# (legado, no usado por el conector Beds24)
CM_API_KEY=
CM_API_SECRET=

# === Búsqueda web (eventos / mercado) ===
# tavily | brave | serper
SEARCH_PROVIDER=tavily
SEARCH_API_KEY=

# === Web (Next.js) ===
NEXT_PUBLIC_API_URL=http://localhost:8000
