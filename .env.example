# Copia este archivo a .env y completa los valores.
# NUNCA subas .env al repositorio.

# === General ===
ENVIRONMENT=development

# === Base de datos (Postgres) ===
DATABASE_URL=postgresql+asyncpg://booking:booking@localhost:5432/booking

# === API (FastAPI) ===
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
SECRET_KEY=cambia-esto-por-un-valor-aleatorio

# === LLM (multi-proveedor vía LiteLLM) ===
# Provider: anthropic | openai | google | ...
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Guarda de presupuesto (opcional)
LLM_MAX_USD_PER_DAY=5

# === Channel Manager (se decide en Fase 2) ===
# beds24 | hostaway | smoobu | lobby
CHANNEL_MANAGER=
CM_API_KEY=
CM_API_SECRET=

# === Búsqueda web (eventos / mercado) ===
# tavily | brave | serper
SEARCH_PROVIDER=tavily
SEARCH_API_KEY=

# === Web (Next.js) ===
NEXT_PUBLIC_API_URL=http://localhost:8000
